# .env.example
# -----------------------------------------------------------------------------
# Configuration file for the Quorum Debate Protocol.
# Duplicate this file to .env and populate all values before execution.
# -----------------------------------------------------------------------------

# Controls the embedding model and fallback language model.
# Expected format: sk-...
OPENAI_API_KEY=sk-proj-example1234567890

# Controls the primary reasoning models (e.g., Llama, Claude, etc.) via OpenRouter.
# Expected format: sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-example1234567890

# Toggles debug mode for verbosity and local logging.
# Expected format: true | false
DEBUG=true
